{
  "pack_id": "glasspane",
  "pack_version": "1.0.0",
  "min_jetpacs_api": "1.5.0",
  "feature": "glasspane",
  "depends": [
    {
      "name": "org",
      "min_version": "9.6"
    },
    {
      "name": "org-ql",
      "min_version": "0.7"
    },
    {
      "name": "vulpea",
      "min_version": "2.0"
    },
    {
      "name": "cl-lib",
      "min_version": "1.0"
    }
  ],
  "layouts": [
    "list",
    "board",
    "calendar"
  ],
  "sources": [
    {
      "name": "glasspane.notes",
      "params": [
        {
          "name": "id",
          "type": "text",
          "required": true
        },
        {
          "name": "relation",
          "type": "enum",
          "required": false,
          "values": [
            "backlinks",
            "outgoing"
          ]
        }
      ],
      "fields": [
        {
          "name": "id",
          "type": "text"
        },
        {
          "name": "title",
          "type": "text"
        },
        {
          "name": "path",
          "type": "text"
        },
        {
          "name": "file_name",
          "type": "text"
        },
        {
          "name": "tags",
          "type": "string-list"
        },
        {
          "name": "ref",
          "type": "ref"
        }
      ]
    },
    {
      "name": "glasspane.org",
      "params": [
        {
          "name": "query",
          "type": "text",
          "required": true
        }
      ],
      "fields": [
        {
          "name": "headline",
          "type": "text"
        },
        {
          "name": "todo",
          "type": "text"
        },
        {
          "name": "scheduled",
          "type": "date"
        },
        {
          "name": "deadline",
          "type": "date"
        },
        {
          "name": "tags",
          "type": "string-list"
        },
        {
          "name": "priority",
          "type": "text"
        },
        {
          "name": "ref",
          "type": "ref"
        }
      ]
    }
  ],
  "actions": [
    {
      "action": "heading.schedule",
      "doc": "Schedule a heading (WHEN relative like \"+1d\", VALUE a date, or CLEAR).",
      "args": [
        {
          "name": "ref",
          "type": "ref",
          "required": true
        },
        {
          "name": "when",
          "type": "text",
          "required": false
        },
        {
          "name": "value",
          "type": "date",
          "required": false
        },
        {
          "name": "clear",
          "type": "bool",
          "required": false
        }
      ]
    },
    {
      "action": "heading.tap",
      "doc": "Open a heading in the detail view.",
      "args": [
        {
          "name": "ref",
          "type": "ref",
          "required": true
        }
      ]
    },
    {
      "action": "heading.todo-cycle",
      "doc": "Cycle a heading through the TODO keyword sequence.",
      "args": [
        {
          "name": "ref",
          "type": "ref",
          "required": true
        }
      ]
    },
    {
      "action": "heading.todo-set",
      "doc": "Set a heading's TODO state; an empty state clears it.",
      "args": [
        {
          "name": "ref",
          "type": "ref",
          "required": true
        },
        {
          "name": "state",
          "type": "text",
          "required": true
        }
      ]
    },
    {
      "action": "journal.capture",
      "doc": "Append text to the current journal day.",
      "args": [
        {
          "name": "value",
          "type": "text",
          "required": true
        },
        {
          "name": "date",
          "type": "date",
          "required": false
        }
      ]
    },
    {
      "action": "notes.mentions",
      "doc": "Scan for unlinked mentions of a note (async ripgrep).",
      "args": [
        {
          "name": "id",
          "type": "text",
          "required": true
        }
      ]
    },
    {
      "action": "search.by-tag",
      "doc": "Filter search to a single tag.",
      "args": [
        {
          "name": "tag",
          "type": "text",
          "required": true
        }
      ]
    },
    {
      "action": "tasks.filter",
      "doc": "Filter the tasks collection to a TODO keyword (or \"ALL\").",
      "args": [
        {
          "name": "filter",
          "type": "text",
          "required": true
        }
      ]
    },
    {
      "action": "views.delete",
      "doc": "Delete a saved view by name.",
      "args": [
        {
          "name": "name",
          "type": "text",
          "required": true
        }
      ]
    },
    {
      "action": "views.open",
      "doc": "Open a saved view by name.",
      "args": [
        {
          "name": "name",
          "type": "text",
          "required": true
        }
      ]
    },
    {
      "action": "views.rendering",
      "doc": "Switch a saved view's rendering (list/board/calendar).",
      "args": [
        {
          "name": "name",
          "type": "text",
          "required": true
        },
        {
          "name": "rendering",
          "type": "enum",
          "required": true,
          "values": [
            "list",
            "board",
            "calendar"
          ]
        }
      ]
    }
  ]
}
