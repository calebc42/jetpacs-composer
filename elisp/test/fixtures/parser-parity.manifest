# Forward-compatible leniency: vocabulary a parser does not know is
# accepted with a warning and surfaced as Unknown (ViewKind.UNKNOWN /
# ColType.Unknown / ActionDef.Unknown on the JVM; `unknown' tokens in
# elisp, rendered as text) so an older runtime can open a newer doc.
coltype-ref accept parser-parity-ref.org
unknown-kind accept parser-parity-unknown-kind.org
unknown-coltype accept malformed-coltype.org
unknown-action accept parser-parity-unknown-action.org

# Pack references (S4.0/S4.2): a well-formed pack:<id>/<name> source or
# action token is accepted whether or not any such pack exists — the view
# degrades at render time instead of the document being rejected.  A source
# scheme neither parser knows is future vocabulary: accepted and preserved
# verbatim, with the view unavailable.  The pack fixture is a FORMAT-4
# document (the writer stamps 4 exactly on pack-backed documents) carrying
# a #+JETPACS_PACK: declaration; format 5 is rejected by the
# unsupported-format row below.
pack-source accept parser-parity-pack.org
pack-action accept parser-parity-pack.org
keyword-jetpacs-pack accept parser-parity-pack.org
format-4-pack accept parser-parity-pack.org
unknown-source-scheme accept parser-parity-unknown-source.org

# FORMAT-2 structural rejection cases: structure stays strict even
# though vocabulary is lenient.
missing-app reject malformed-no-app.org
unsupported-format reject parser-parity-unsupported-format.org
duplicate-view-slug reject malformed-dup.org
todo-missing-argument reject parser-parity-todo-missing-argument.org
action-unexpected-argument reject parser-parity-action-unexpected-argument.org
malformed-actions reject parser-parity-malformed-actions.org
empty-enum reject parser-parity-empty-enum.org
duplicate-schema reject parser-parity-duplicate-schema.org
records-missing-schema reject parser-parity-records-missing-schema.org
notes-missing-source reject parser-parity-notes-missing-source.org
ref-too-many-arguments reject parser-parity-ref-too-many-arguments.org
malformed-pack-source reject parser-parity-malformed-pack-source.org
malformed-pack-action reject parser-parity-malformed-pack-action.org
malformed-pack-keyword reject parser-parity-malformed-pack-keyword.org
